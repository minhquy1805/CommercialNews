# ==================================================
# INFRA - SQL Server
# ==================================================
SA_PASSWORD=change_me_strong_sa_password

# ==================================================
# API - SQL
# ==================================================
API_SQL_CONNECTION_STRING=Server=cn-mssql,1433;Database=CommercialNews;User Id=cn_api_login;Password=change_me_api_db_password;TrustServerCertificate=True;Encrypt=True;

# ==================================================
# API - Identity Tokens
# ==================================================
API_EMAIL_VERIFICATION_TOKEN_LIFETIME_HOURS=24
API_PASSWORD_RESET_TOKEN_LIFETIME_HOURS=1
API_REFRESH_TOKEN_LIFETIME_DAYS=30

# ==================================================
# API - JWT
# ==================================================
API_JWT_ISSUER=CommercialNews
API_JWT_AUDIENCE=CommercialNews.Api
API_JWT_SECRET_KEY=change_me_long_random_jwt_secret
API_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# ==================================================
# API - Default Admin
# ==================================================
API_DEFAULT_ADMIN_ENABLED=true
API_DEFAULT_ADMIN_EMAIL=admin@example.com
API_DEFAULT_ADMIN_PASSWORD=change_me_admin_password
API_DEFAULT_ADMIN_FULLNAME=CommercialNews System Administrator

# ==================================================
# API - Authorization Default Admin
# ==================================================
API_AUTHORIZATION_DEFAULT_ADMIN_ENABLED=true
API_AUTHORIZATION_DEFAULT_ADMIN_EMAIL=admin@example.com

# ==================================================
# API - ASP.NET
# ==================================================
API_ALLOWED_HOSTS=*

# ==================================================
# WORKER - SQL
# ==================================================
WORKER_SQL_CONNECTION_STRING=Server=cn-mssql,1433;Database=CommercialNews;User Id=cn_worker_login;Password=change_me_worker_db_password;TrustServerCertificate=True;Encrypt=True;

# ==================================================
# WORKER - Outbox Worker
# ==================================================
WORKER_OUTBOX_IS_ENABLED=true
WORKER_OUTBOX_BATCH_SIZE=50
WORKER_OUTBOX_POLL_INTERVAL_SECONDS=10
WORKER_OUTBOX_ERROR_DELAY_SECONDS=5
WORKER_OUTBOX_STOP_ON_FIRST_FAILURE=false
WORKER_OUTBOX_BUSY_DELAY_SECONDS=1

WORKER_OUTBOX_PROCESSING_MAX_RETRY_ATTEMPTS=5
WORKER_OUTBOX_PROCESSING_INITIAL_RETRY_DELAY_SECONDS=30
WORKER_OUTBOX_PROCESSING_MAX_RETRY_DELAY_SECONDS=900

# ==================================================
# WORKER - Email Delivery Processing
# ==================================================
WORKER_EMAIL_DELIVERY_PROCESSING_IS_ENABLED=true
WORKER_EMAIL_DELIVERY_PROCESSING_BATCH_SIZE=50
WORKER_EMAIL_DELIVERY_PROCESSING_POLL_INTERVAL_SECONDS=10
WORKER_EMAIL_DELIVERY_PROCESSING_BUSY_DELAY_SECONDS=1
WORKER_EMAIL_DELIVERY_PROCESSING_ERROR_DELAY_SECONDS=5

# ==================================================
# WORKER - Email SMTP
# ==================================================
WORKER_EMAIL_HOST=smtp.gmail.com
WORKER_EMAIL_PORT=587
WORKER_EMAIL_USE_SSL=false
WORKER_EMAIL_FROM_NAME=CommercialNews
WORKER_EMAIL_FROM_EMAIL=no-reply@example.com
WORKER_EMAIL_USERNAME=no-reply@example.com
WORKER_EMAIL_PASSWORD=change_me_smtp_password
WORKER_EMAIL_TIMEOUT_MILLISECONDS=10000

WORKER_EMAIL_TEMPLATE_DIRECTORY=EmailTemplates

# ==================================================
# WORKER - Notification Delivery
# ==================================================
WORKER_NOTIFICATION_PROVIDER=smtp
WORKER_VERIFICATION_EMAIL_PRIORITY=1
WORKER_PASSWORD_RESET_PRIORITY=1
WORKER_PASSWORD_CHANGED_PRIORITY=3
WORKER_EMAIL_VERIFIED_PRIORITY=5
WORKER_EMAIL_MAX_ATTEMPT_COUNT=5
WORKER_EMAIL_INITIAL_RETRY_DELAY_SECONDS=30
WORKER_EMAIL_MAX_RETRY_DELAY_SECONDS=900
WORKER_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000

# ==================================================
# RABBITMQ - Shared
# ==================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=commercialnews
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_EXCHANGE_NAME=commercialnews.events
RABBITMQ_EXCHANGE_TYPE=topic

# ==================================================
# RABBITMQ - Outbox Publisher
# ==================================================
RABBITMQ_OUTBOX_DURABLE_EXCHANGE=true
RABBITMQ_OUTBOX_PERSISTENT_MESSAGES=true
RABBITMQ_OUTBOX_PUBLISH_TIMEOUT_SECONDS=10
RABBITMQ_OUTBOX_CLIENT_PROVIDED_NAME=CommercialNews.Outbox.Worker

# ==================================================
# RABBITMQ - Notifications Consumer
# ==================================================
RABBITMQ_NOTIFICATIONS_QUEUE_NAME=notifications.identity.email
RABBITMQ_NOTIFICATIONS_DURABLE_QUEUE=true
RABBITMQ_NOTIFICATIONS_EXCLUSIVE_QUEUE=false
RABBITMQ_NOTIFICATIONS_AUTO_DELETE_QUEUE=false
RABBITMQ_NOTIFICATIONS_PREFETCH_COUNT=10
RABBITMQ_NOTIFICATIONS_CONSUMER_TAG=CommercialNews.Notifications.Consumer
RABBITMQ_NOTIFICATIONS_CLIENT_PROVIDED_NAME=CommercialNews.Notifications.Consumer
RABBITMQ_NOTIFICATIONS_REQUEUE_ON_FAILURE=true

# ==================================================
# RABBITMQ - Audit Consumer
# ==================================================
RABBITMQ_AUDIT_QUEUE_NAME=audit.events
RABBITMQ_AUDIT_DURABLE_QUEUE=true
RABBITMQ_AUDIT_EXCLUSIVE_QUEUE=false
RABBITMQ_AUDIT_AUTO_DELETE_QUEUE=false
RABBITMQ_AUDIT_PREFETCH_COUNT=10
RABBITMQ_AUDIT_CONSUMER_TAG=CommercialNews.Audit.Consumer
RABBITMQ_AUDIT_CLIENT_PROVIDED_NAME=CommercialNews.Audit.Consumer
RABBITMQ_AUDIT_REQUEUE_ON_FAILURE=true