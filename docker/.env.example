RABBITMQ_AUTHORIZATION_QUEUE_NAME=authorization.identity.user-registrations
RABBITMQ_AUTHORIZATION_DURABLE_QUEUE=true
RABBITMQ_AUTHORIZATION_EXCLUSIVE_QUEUE=false
RABBITMQ_AUTHORIZATION_AUTO_DELETE_QUEUE=false
RABBITMQ_AUTHORIZATION_PREFETCH_COUNT=10
RABBITMQ_AUTHORIZATION_CONSUMER_TAG=CommercialNews.Authorization.Consumer
RABBITMQ_AUTHORIZATION_CLIENT_PROVIDED_NAME=CommercialNews.Authorization.Consumer
RABBITMQ_AUTHORIZATION_REQUEUE_ON_FAILURE=true

