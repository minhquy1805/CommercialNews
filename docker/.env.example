RABBITMQ_AUDIT_CLIENT_PROVIDED_NAME=CommercialNews.Audit.Consumer
RABBITMQ_AUDIT_CONSUMER_NAME=CommercialNews.Audit.Consumer
RABBITMQ_AUDIT_REQUEUE_ON_FAILURE=true

