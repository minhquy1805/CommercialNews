// =====================================================
// CommercialNews — Interaction Module (V1) — dbdiagram.io
// File: explanation/architecture/arc42/diagrams/erd/interaction-v1.dbml
//
// Purpose
// - Track views/likes/comments without blocking the public read path.
// - Provide derived counters for later Reading enrichment / popularity sorting.
//
// Design notes
// - ArticleViewEvent is a high-write append-only log -> keep indexes minimal.
// - ArticleLike is idempotent via UNIQUE (ArticleId, UserId) and toggle IsActive.
// - Comment is soft-lifecycle; public reads only Visible.
// - ArticleInteractionStats is derived; missing row => treat totals as 0.
// =====================================================

Enum CommentStatusEnum {
  Visible
  Hidden
  Deleted
  Pending
}

Table ArticleViewEvent {
  ArticleViewEventId bigint [pk, increment]

  ArticleId bigint [not null]       // logical ref -> Content.Article
  UserId bigint [null]              // nullable for anonymous views
  VisitorKey nvarchar(100) [null]   // optional policy hook

  ViewedAt datetime2(3) [not null, default: `SYSUTCDATETIME()`]
  IpAddress nvarchar(64) [null]
  UserAgent nvarchar(512) [null]

  Indexes {
    (ArticleId) [name: "IX_ArticleViewEvent_ArticleId"]
    (ViewedAt)  [name: "IX_ArticleViewEvent_ViewedAt"]
  }

  Note: "Append-only high-write log. Public read path must not depend on this table."
}

Table ArticleLike {
  ArticleLikeId bigint [pk, increment]

  ArticleId bigint [not null]       // logical ref -> Content.Article
  UserId bigint [not null]          // logical ref -> Identity.UserAccount

  IsActive bit [not null, default: 1]
  LikedAt datetime2(3) [not null, default: `SYSUTCDATETIME()`]
  UnlikedAt datetime2(3) [null]

  CreatedAt datetime2(3) [not null, default: `SYSUTCDATETIME()`]
  UpdatedAt datetime2(3) [null]

  Indexes {
    (ArticleId, UserId) [unique, name: "UQ_ArticleLike_ArticleId_UserId"]
    (ArticleId, IsActive) [name: "IX_ArticleLike_ArticleId_IsActive"]
  }

  Note: "Idempotent like truth. One row per (ArticleId, UserId); toggle IsActive for unlike/relike."
}

Table Comment {
  CommentId bigint [pk, increment]

  ArticleId bigint [not null]          // logical ref -> Content.Article
  UserId bigint [not null]             // author -> Identity.UserAccount
  ParentCommentId bigint [null]        // optional threading

  Content nvarchar(2000) [not null]
  Status nvarchar(20) [not null, default: "Visible"]

  CreatedAt datetime2(3) [not null, default: `SYSUTCDATETIME()`]
  UpdatedAt datetime2(3) [null]
  DeletedAt datetime2(3) [null]
  DeletedByUserId bigint [null]

  EditCount int [not null, default: 0]

  Indexes {
    (ArticleId, Status, CreatedAt) [name: "IX_Comment_ArticleId_Status_CreatedAt"]
    (ParentCommentId, CreatedAt)   [name: "IX_Comment_ParentCommentId_CreatedAt"]
  }

  Note: "Comment truth with soft lifecycle. Public reads only Status = Visible."
}

Table ArticleInteractionStats {
  ArticleId bigint [pk] // derived projection: 0..1 per article

  ViewsTotal bigint [not null, default: 0]
  LikesTotal bigint [not null, default: 0]
  CommentsTotal bigint [not null, default: 0]

  PopularityScore decimal(18,4) [not null, default: 0]

  CreatedAt datetime2(3) [not null, default: `SYSUTCDATETIME()`]
  UpdatedAt datetime2(3) [null]
  LastAggregatedAt datetime2(3) [null]

  Indexes {
    (PopularityScore, ArticleId) [name: "IX_ArticleInteractionStats_PopularityScore"]
    (UpdatedAt)                  [name: "IX_ArticleInteractionStats_UpdatedAt"]
  }

  Note: "Derived/materialized counters. Missing row means safe fallback to zero."
}

// ---------- Cross-module stubs (ERD readability only) ----------
Table ContentArticle {
  ArticleId bigint [pk]
  Note: "EXTERNAL (Content module). Logical reference only."
}

Table IdentityUserAccount {
  UserId bigint [pk]
  Note: "EXTERNAL (Identity module). Logical reference only."
}

// ---------- Logical relationships ----------
Ref: ArticleViewEvent.ArticleId > ContentArticle.ArticleId
Ref: ArticleLike.ArticleId > ContentArticle.ArticleId
Ref: Comment.ArticleId > ContentArticle.ArticleId
Ref: ArticleInteractionStats.ArticleId > ContentArticle.ArticleId

Ref: ArticleViewEvent.UserId > IdentityUserAccount.UserId
Ref: ArticleLike.UserId > IdentityUserAccount.UserId
Ref: Comment.UserId > IdentityUserAccount.UserId
Ref: Comment.DeletedByUserId > IdentityUserAccount.UserId

Ref: Comment.ParentCommentId > Comment.CommentId

// ---------- SQL Server enforcement notes ----------
// 1) CHECK [Status] IN ('Visible','Hidden','Deleted','Pending')
// 2) CHECK [ViewsTotal] >= 0 AND [LikesTotal] >= 0 AND [CommentsTotal] >= 0
// 3) CHECK [EditCount] >= 0
// 4) Retention/purge for ArticleViewEvent by ViewedAt
// 5) Cross-module refs are logical; physical FK constraints are optional and not required for V1
// 6) ArticleInteractionStats is derived and must never be treated as correctness truth