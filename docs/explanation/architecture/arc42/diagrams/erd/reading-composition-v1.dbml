// =====================================================
// CommercialNews — Reading Module (V1 Async Projections)
// File: docs/explanation/architecture/arc42/diagrams/erd/reading-composition-v1.dbml
//
// Purpose
// - Model Reading-owned public serving projections.
// - Reading serves ordinary public APIs from local projection data only.
// - Source modules remain authoritative for their source truth.
// - Each upstream projection lane is independently versioned.
// - Projection state is derived, idempotent, repairable and rebuildable.
//
// Source ownership
// - Content owns article lifecycle, editorial fields and public visibility truth.
// - SEO owns canonical slug, route and metadata truth.
// - Media owns media asset and public presentation truth.
// - Interaction owns views, likes, comments, moderation and counter truth.
//
// V1 decisions
// - Slug detail uses [reading].[ArticleSeoRouteProjection] locally.
// - Interaction counters are received as known-value snapshots.
// - Media is projected independently from Content.
// - Popularity / trending is deferred beyond V1.
// - Reading does not synchronously query source modules during ordinary reads.
// - Reading V1 does not introduce a dedicated ConsumedMessage / Inbox table.
// - Consumer safety relies on source-specific version-aware apply.
// - No physical FK is required between independently delivered source lanes.
// =====================================================


// =====================================================
// 1) Content lane — public article serving projection
// =====================================================

Table reading.ArticleReadModel {
  ArticleReadModelId bigint [pk, increment]

  ArticlePublicId char(26) [not null, unique]

  // Projected public article content from Content
  Title nvarchar(300) [not null]
  Summary nvarchar(1000) [null]
  Body nvarchar(max) [not null]

  // Projected taxonomy / author presentation from Content
  CategoryPublicId char(26) [null]
  CategoryName nvarchar(200) [null]
  AuthorUserId bigint [null]
  AuthorDisplayName nvarchar(200) [null]

  // Content-derived public visibility
  Status nvarchar(30) [not null]
  IsPublic bit [not null, default: 0]
  VisibilityRequiresResync bit [not null, default: 0]

  PublishedAtUtc datetime2(3) [null]
  ArticleUpdatedAtUtc datetime2(3) [null]

  // Optional public search materialization
  SearchText nvarchar(max) [null]

  // Content-lane freshness / diagnostics
  ContentSourceVersion bigint [not null]
  ContentLastMessageId char(26) [not null]
  ContentLastSourceOccurredAtUtc datetime2(3) [not null]
  LastContentAppliedAtUtc datetime2(3) [not null]

  CreatedAtUtc datetime2(3) [not null]
  UpdatedAtUtc datetime2(3) [null]

  Indexes {
    (ArticlePublicId)
      [unique, name: "UQ_ArticleReadModel_ArticlePublicId"]

    (IsPublic, Status, VisibilityRequiresResync, PublishedAtUtc, ArticlePublicId)
      [name: "IX_ArticleReadModel_Public_PublishedAt"]

    (CategoryPublicId, IsPublic, Status, VisibilityRequiresResync, PublishedAtUtc, ArticlePublicId)
      [name: "IX_ArticleReadModel_Category_Public_PublishedAt"]
  }

  Note: '''
  DERIVED: Reading-owned public article projection applied from Content snapshots.

  Public serving condition:
    Status = Published
    AND IsPublic = 1
    AND VisibilityRequiresResync = 0.

  ContentSourceVersion protects this Content lane from stale overwrite.

  Missing, non-public or unsafe rows must not be publicly served.
  '''
}


// =====================================================
// 2) Content lane child — projected public tags
// =====================================================

Table reading.ArticleTagProjection {
  ArticlePublicId char(26) [not null]
  TagPublicId char(26) [not null]

  Name nvarchar(200) [not null]
  Slug nvarchar(250) [null]

  Indexes {
    (ArticlePublicId, TagPublicId)
      [pk, name: "PK_ArticleTagProjection"]

    (TagPublicId, ArticlePublicId)
      [name: "IX_ArticleTagProjection_TagPublicId_ArticlePublicId"]
  }

  Note: '''
  DERIVED: Public tag projection applied together with the Content article snapshot.

  Supports:
    - public detail tag output
    - tag filtering
    - basic related-article candidate queries

  When a newer Content snapshot removes all tags, existing tag rows for the
  article are deleted within the same local Content projection transaction.
  '''
}


// =====================================================
// 3) SEO lane — local public slug route / metadata projection
// =====================================================

Table reading.ArticleSeoRouteProjection {
  ArticleSeoRouteProjectionId bigint [pk, increment]

  Scope nvarchar(30) [not null]
  Slug nvarchar(250) [not null]
  ArticlePublicId char(26) [not null]

  // Projected public SEO response data
  CanonicalUrl nvarchar(500) [null]
  MetaTitle nvarchar(300) [null]
  MetaDescription nvarchar(500) [null]

  // Local route serving safety
  IsActive bit [not null, default: 0]
  RequiresResync bit [not null, default: 0]

  // SEO-lane freshness / diagnostics
  SeoSourceVersion bigint [not null]
  SeoLastMessageId char(26) [not null]
  SeoLastSourceOccurredAtUtc datetime2(3) [not null]
  LastSeoAppliedAtUtc datetime2(3) [not null]

  CreatedAtUtc datetime2(3) [not null]
  UpdatedAtUtc datetime2(3) [null]

  Indexes {
    (Scope, Slug)
      [unique, name: "UQ_ArticleSeoRouteProjection_Scope_Slug"]

    (ArticlePublicId, Scope, IsActive, RequiresResync)
      [name: "IX_ArticleSeoRouteProjection_ArticlePublicId_Serving"]
  }

  Note: '''
  DERIVED: Reading-owned route projection applied from SEO snapshots.

  Slug-serving condition:
    Scope = public
    AND IsActive = 1
    AND RequiresResync = 0.

  A safe route is necessary but not sufficient:
  its ArticlePublicId target must also resolve to a safely public
  reading.ArticleReadModel row.

  No FK to ArticleReadModel is enforced because SEO projection may arrive
  before the Content projection during asynchronous delivery.
  '''
}


// =====================================================
// 4) Media lane header — per-article media snapshot state
// =====================================================

Table reading.ArticleMediaProjectionState {
  ArticlePublicId char(26) [pk, not null]

  // Media-lane freshness / diagnostics
  MediaSourceVersion bigint [not null]
  MediaLastMessageId char(26) [not null]
  MediaLastSourceOccurredAtUtc datetime2(3) [not null]
  LastMediaAppliedAtUtc datetime2(3) [not null]

  RequiresResync bit [not null, default: 0]

  CreatedAtUtc datetime2(3) [not null]
  UpdatedAtUtc datetime2(3) [null]

  Note: '''
  DERIVED: Header/state row for the independently delivered Media lane.

  This row preserves the latest MediaSourceVersion even when an article has
  zero currently available public media items.

  Without this state row, an empty gallery or removed cover would have no
  persisted version marker and an older media snapshot could be reapplied.

  No FK to ArticleReadModel is enforced because Media projection may arrive
  before the Content projection.
  '''
}


// =====================================================
// 5) Media lane child — projected public media items
// =====================================================

Table reading.ArticleMediaItemProjection {
  ArticlePublicId char(26) [not null]
  MediaPublicId char(26) [not null]

  Url nvarchar(1000) [not null]
  AltText nvarchar(500) [null]
  MediaType nvarchar(30) [not null]

  SortOrder int [not null, default: 0]
  IsPrimary bit [not null, default: 0]
  IsAvailable bit [not null, default: 1]

  CreatedAtUtc datetime2(3) [not null]
  UpdatedAtUtc datetime2(3) [null]

  Indexes {
    (ArticlePublicId, MediaPublicId)
      [pk, name: "PK_ArticleMediaItemProjection"]

    (ArticlePublicId, IsAvailable, IsPrimary, SortOrder, MediaPublicId)
      [name: "IX_ArticleMediaItemProjection_Article_Primary_Order"]

    (ArticlePublicId, IsAvailable, SortOrder, MediaPublicId)
      [name: "IX_ArticleMediaItemProjection_Article_Gallery_Order"]
  }

  Note: '''
  DERIVED: Public media item rows belonging to the latest accepted
  reading.ArticleMediaProjectionState snapshot.

  Missing media safely degrades the public response.

  Media rows never decide article public visibility.
  '''
}


// =====================================================
// 6) Interaction lane — displayed counter snapshot projection
// =====================================================

Table reading.ArticleInteractionCounterProjection {
  ArticlePublicId char(26) [pk, not null]

  ViewCount bigint [not null, default: 0]
  LikeCount bigint [not null, default: 0]
  VisibleCommentCount bigint [not null, default: 0]

  // Interaction-lane freshness / diagnostics
  InteractionStatsVersion bigint [not null]
  InteractionLastMessageId char(26) [not null]
  InteractionLastSourceOccurredAtUtc datetime2(3) [not null]
  LastInteractionAppliedAtUtc datetime2(3) [not null]

  CreatedAtUtc datetime2(3) [not null]
  UpdatedAtUtc datetime2(3) [null]

  Note: '''
  DERIVED: Reading-owned displayed counter snapshot applied from:

    interaction.article_counters_projection_published

  Apply rule:
    Apply only when IncomingStatsVersion > InteractionStatsVersion.

  Counter values are optional public enrichments only.
  Counters never determine article visibility.

  Reading never builds these totals through blind increment processing.

  No FK to ArticleReadModel is enforced because an Interaction counter
  snapshot may arrive before the Content projection.
  '''
}


// =====================================================
// Local projection relationships
// =====================================================

// Content article and tag projection are applied as one Content-owned snapshot
// boundary, therefore a local relationship is acceptable.
Ref: reading.ArticleTagProjection.ArticlePublicId > reading.ArticleReadModel.ArticlePublicId

// Media item rows belong to their local media snapshot state.
// This relationship stays entirely inside the independent Media projection lane.
Ref: reading.ArticleMediaItemProjection.ArticlePublicId > reading.ArticleMediaProjectionState.ArticlePublicId


// =====================================================
// Logical serving composition — local Reading joins only
// =====================================================
//
// Public list/detail/search/related responses may compose:
//
// reading.ArticleReadModel
//   LEFT JOIN reading.ArticleSeoRouteProjection
//     ON ArticlePublicId
//   LEFT JOIN reading.ArticleMediaProjectionState
//     ON ArticlePublicId
//   LEFT JOIN reading.ArticleMediaItemProjection
//     ON ArticlePublicId
//   LEFT JOIN reading.ArticleInteractionCounterProjection
//     ON ArticlePublicId
//   LEFT JOIN reading.ArticleTagProjection
//     ON ArticlePublicId
//
// These joins are local Reading composition only.
// They do not query Content, SEO, Media or Interaction truth during
// ordinary public request handling.
//
// For list responses that require a slug link, the response should use a safe,
// active public ArticleSeoRouteProjection row. If no safe route has arrived,
// the article should be omitted from slug-linked results or the API contract
// must explicitly allow a missing slug.


// =====================================================
// Consumer idempotency notes
// =====================================================
//
// Reading V1 does not introduce a dedicated ReadingConsumedMessage table.
//
// Projection consumers rely on snapshot-shaped inputs and atomic,
// source-specific version-aware persistence:
//
// reading.ArticleReadModel
//   -> apply only when IncomingContentSourceVersion > ContentSourceVersion
//
// reading.ArticleSeoRouteProjection
//   -> apply only when IncomingSeoSourceVersion > SeoSourceVersion
//
// reading.ArticleMediaProjectionState + ArticleMediaItemProjection
//   -> replace media item set only when
//      IncomingMediaSourceVersion > MediaSourceVersion
//
// reading.ArticleInteractionCounterProjection
//   -> apply only when IncomingStatsVersion > InteractionStatsVersion
//
// Duplicate or stale deliveries must become safe no-ops.
//
// RabbitMQ message acknowledgement occurs only after local projection
// persistence succeeds.
//
// If future Reading consumers introduce non-idempotent downstream effects,
// delta-style mutation processing, or durable per-message audit/replay
// requirements, an Inbox / ConsumedMessage mechanism must be reconsidered.


// =====================================================
// Source lineage notes — no cross-module physical FK
// =====================================================
//
// reading.ArticleReadModel
//   <- Content public article projection snapshot
//
// reading.ArticleTagProjection
//   <- Content public article projection snapshot
//
// reading.ArticleSeoRouteProjection
//   <- SEO public route / metadata projection snapshot
//
// reading.ArticleMediaProjectionState
// reading.ArticleMediaItemProjection
//   <- Media public presentation projection snapshot
//
// reading.ArticleInteractionCounterProjection
//   <- interaction.article_counters_projection_published
//
// Source modules retain truth ownership.
//
// Popularity / trending projection is intentionally not modeled in V1.